# Supabase — required for auth and cloud save/load
# Get these from: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: restrict dev server to specific hosts (comma-separated)
# MINDMAPP_ALLOWED_HOSTS=localhost,127.0.0.1
# MINDMAPP_PORT=5180

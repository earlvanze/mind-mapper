# Mind Mapp static deploy cache controls.
# Keep the SPA shell fresh so deploys don't get stuck on an old asset manifest.
<IfModule LiteSpeed>
  CacheDisable public /
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  <FilesMatch "\.(js|css|svg|png|jpg|jpeg|gif|webp|woff2?|ttf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
